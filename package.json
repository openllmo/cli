{
  "name": "llmo",
  "version": "0.1.0",
  "description": "Reference CLI for the LLMO protocol. Sign and verify llmo.json documents per the v0.1 specification at https://llmo.org/spec/v0.1.",
  "type": "module",
  "bin": {
    "llmo": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/schema/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "test": "node --test --import tsx ./test/*.test.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "llmo",
    "well-known",
    "jws",
    "jcs",
    "rfc7515",
    "rfc8785",
    "rfc8615",
    "organizational-identity",
    "signed-claims"
  ],
  "homepage": "https://llmo.org/spec/v0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openllmo/cli.git"
  },
  "bugs": {
    "url": "https://github.com/openllmo/cli/issues"
  },
  "author": "Nic Chavez <spec@llmo.org>",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "canonicalize": "^2.0.0",
    "commander": "^12.1.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
